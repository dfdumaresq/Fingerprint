# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
# Use a long random string — e.g. openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── API ───────────────────────────────────────────────────────────────────────
# Bearer token clients must send in Authorization header
API_KEY=sk_prod_CHANGE_ME

# ── Blockchain (Sepolia) ──────────────────────────────────────────────────────
SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
PRIVATE_KEY=YOUR_WALLET_PRIVATE_KEY_HEX

# ── Key Management ────────────────────────────────────────────────────────────
MASTER_KEY_PASSWORD=CHANGE_ME_strong_master_password
