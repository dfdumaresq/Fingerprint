{
  "name": "fingerprint",
  "version": "1.0.0",
  "description": "AI Agent Fingerprinting System using blockchain",
  "main": "index.js",
  "scripts": {
    "start": "webpack serve --mode development --open",
    "build": "webpack --mode production",
    "test": "hardhat test",
    "test:jest": "jest",
    "test:all": "npm run test && npm run test:jest",
    "compile": "hardhat compile",
    "deploy:local": "hardhat run scripts/deploy.js --network hardhat",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "dev:indexer": "ts-node scripts/indexer.ts",
    "dev:api": "ts-node src/api/server.ts",
    "register:agent": "hardhat run scripts/register-agent.js --network sepolia",
    "prune:agent": "ts-node scripts/prune-agent.ts",
    "batch-register": "ts-node scripts/batch-register.ts",
    "compare-models": "ts-node scripts/compare-models.ts",
    "seed:agents": "ts-node scripts/seed-demo-agents.ts",
    "dev:medical": "node scripts/init-medical-db.js && ts-node src/api/server.ts",
    "simulate:medical": "ts-node scripts/simulate-clinical-events.ts"
  },
  "keywords": [
    "blockchain",
    "fingerprint",
    "ai",
    "agent",
    "verification"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@openzeppelin/contracts": "^5.3.0",
    "@trustnxt/c2pa-ts": "^0.10.0",
    "@types/node": "^22.15.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "ethers": "^6.13.7",
    "express": "^5.2.1",
    "fast-json-stable-stringify": "^2.1.0",
    "ioredis": "^5.10.0",
    "pg": "^8.20.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.8.3",
    "uuid": "^13.0.0",
    "web3": "^4.16.0",
    "web3modal": "^1.9.12",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.12",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "css-loader": "^7.1.2",
    "hardhat": "^2.23.0",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "style-loader": "^4.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "webpack": "^5.99.7",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.1"
  }
}
